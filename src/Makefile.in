# node #
libfjarcode_node_a_CPPFLAGS = $(AM_CPPFLAGS) $(FJARCODE_INCLUDES) \
	$(LEVELDB_CPPFLAGS) $(BOOST_CPPFLAGS) $(MINIUPNPC_CPPFLAGS) \
	$(NATPMP_CPPFLAGS) $(EVENT_CFLAGS) $(EVENT_PTHREADS_CFLAGS) \
	$(am__append_15)
libfjarcode_node_a_CXXFLAGS = $(AM_CXXFLAGS) $(PIE_FLAGS)
libfjarcode_node_a_SOURCES = addrdb.cpp addrman.cpp banman.cpp \
	bip324.cpp blockencodings.cpp blockfilter.cpp chain.cpp \
	consensus/tx_verify.cpp dbwrapper.cpp deploymentstatus.cpp \
	dsp/dspid.h dsp/dsproof.cpp dsp/dsproof.h \
