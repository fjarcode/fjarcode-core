@ENABLE_QT_TRUE@FJARCODE_QT_CPP = $(FJARCODE_QT_BASE_CPP) \
@ENABLE_QT_TRUE@	$(am__append_79) $(am__append_80)
@ENABLE_QT_TRUE@QT_RES_ANIMATION = $(wildcard $(srcdir)/qt/res/animation/spinner-*.png)
@ENABLE_QT_TRUE@FJARCODE_QT_RC = qt/res/fjarcode-qt-res.rc
@ENABLE_QT_TRUE@FJARCODE_QT_INCLUDES = -DQT_NO_KEYWORDS -DQT_USE_QSTRINGBUILDER
@ENABLE_QT_TRUE@qt_libfjarcodeqt_a_CPPFLAGS = $(AM_CPPFLAGS) $(FJARCODE_INCLUDES) $(FJARCODE_QT_INCLUDES) \
@ENABLE_QT_TRUE@  $(QT_INCLUDES) $(QT_DBUS_INCLUDES) $(QR_CFLAGS) $(BOOST_CPPFLAGS)

@ENABLE_QT_TRUE@qt_libfjarcodeqt_a_CXXFLAGS = $(AM_CXXFLAGS) $(QT_PIE_FLAGS)
@ENABLE_QT_TRUE@qt_libfjarcodeqt_a_OBJCXXFLAGS = $(AM_OBJCXXFLAGS) $(QT_PIE_FLAGS)
@ENABLE_QT_TRUE@qt_libfjarcodeqt_a_SOURCES = $(FJARCODE_QT_CPP) \
@ENABLE_QT_TRUE@	$(FJARCODE_QT_H) $(QT_FORMS_UI) $(QT_QRC) \
@ENABLE_QT_TRUE@	$(QT_QRC_LOCALE) $(QT_TS) $(QT_RES_FONTS) \
@ENABLE_QT_TRUE@	$(QT_RES_ICONS) $(QT_RES_ANIMATION) \
@ENABLE_QT_TRUE@	$(am__append_81)
@ENABLE_QT_TRUE@nodist_qt_libfjarcodeqt_a_SOURCES = $(QT_MOC_CPP) $(QT_MOC) $(QT_QRC_CPP) $(QT_QRC_LOCALE_CPP)

# forms/foo.h -> forms/ui_foo.h
@ENABLE_QT_TRUE@QT_FORMS_H = $(join $(dir $(QT_FORMS_UI)),$(addprefix ui_, $(notdir $(QT_FORMS_UI:.ui=.h))))

# fjarcode-qt and fjarcode-gui binaries #
@ENABLE_QT_TRUE@fjarcode_qt_cppflags = $(AM_CPPFLAGS) $(FJARCODE_INCLUDES) $(FJARCODE_QT_INCLUDES) \
@ENABLE_QT_TRUE@  $(QT_INCLUDES) $(QR_CFLAGS)

@ENABLE_QT_TRUE@fjarcode_qt_cxxflags = $(AM_CXXFLAGS) $(QT_PIE_FLAGS)
@ENABLE_QT_TRUE@fjarcode_qt_sources = qt/main.cpp $(am__append_82)
@ENABLE_QT_TRUE@fjarcode_qt_ldadd = qt/libfjarcodeqt.a \
@ENABLE_QT_TRUE@	$(LIBFJARCODE_NODE) $(am__append_83) \
@ENABLE_QT_TRUE@	$(am__append_84) $(LIBFJARCODE_CLI) \
@ENABLE_QT_TRUE@	$(LIBFJARCODE_COMMON) $(LIBFJARCODE_UTIL) \
@ENABLE_QT_TRUE@	$(LIBFJARCODE_CONSENSUS) $(LIBFJARCODE_CRYPTO) \
@ENABLE_QT_TRUE@	$(LIBUNIVALUE) $(LIBLEVELDB) $(LIBMEMENV) \
@ENABLE_QT_TRUE@	$(QT_LIBS) $(QT_DBUS_LIBS) $(QR_LIBS) \
@ENABLE_QT_TRUE@	$(BDB_LIBS) $(MINIUPNPC_LIBS) $(NATPMP_LIBS) \
@ENABLE_QT_TRUE@	$(LIBSECP256K1) $(EVENT_PTHREADS_LIBS) \
@ENABLE_QT_TRUE@	$(EVENT_LIBS) $(SQLITE_LIBS)
@ENABLE_QT_TRUE@fjarcode_qt_ldflags = $(RELDFLAGS) $(AM_LDFLAGS) $(QT_LDFLAGS) $(LIBTOOL_APP_LDFLAGS) $(PTHREAD_FLAGS)
@ENABLE_QT_TRUE@fjarcode_qt_libtoolflags = $(AM_LIBTOOLFLAGS) --tag CXX
@ENABLE_QT_TRUE@qt_fjarcode_qt_CPPFLAGS = $(fjarcode_qt_cppflags)
@ENABLE_QT_TRUE@qt_fjarcode_qt_CXXFLAGS = $(fjarcode_qt_cxxflags)
@ENABLE_QT_TRUE@qt_fjarcode_qt_SOURCES = $(fjarcode_qt_sources) init/fjarcode-qt.cpp
@ENABLE_QT_TRUE@qt_fjarcode_qt_LDADD = $(fjarcode_qt_ldadd)
@ENABLE_QT_TRUE@qt_fjarcode_qt_LDFLAGS = $(fjarcode_qt_ldflags)
@ENABLE_QT_TRUE@qt_fjarcode_qt_LIBTOOLFLAGS = $(fjarcode_qt_libtoolflags)
@ENABLE_QT_TRUE@fjarcode_gui_CPPFLAGS = $(fjarcode_qt_cppflags)
@ENABLE_QT_TRUE@fjarcode_gui_CXXFLAGS = $(fjarcode_qt_cxxflags)
@ENABLE_QT_TRUE@fjarcode_gui_SOURCES = $(fjarcode_qt_sources) init/fjarcode-gui.cpp
