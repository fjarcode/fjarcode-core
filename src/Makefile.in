DIST_SUBDIRS = secp256k1
AM_LDFLAGS = $(LIBTOOL_LDFLAGS) $(HARDENED_LDFLAGS) $(GPROF_LDFLAGS) $(SANITIZER_LDFLAGS) $(CORE_LDFLAGS)
AM_CXXFLAGS = $(CORE_CXXFLAGS) $(DEBUG_CXXFLAGS) $(HARDENED_CXXFLAGS) $(WARN_CXXFLAGS) $(NOWARN_CXXFLAGS) $(ERROR_CXXFLAGS) $(GPROF_CXXFLAGS) $(SANITIZER_CXXFLAGS)
AM_CPPFLAGS = $(DEBUG_CPPFLAGS) $(HARDENED_CPPFLAGS) $(CORE_CPPFLAGS)
AM_LIBTOOLFLAGS = --preserve-dup-deps
PTHREAD_FLAGS = $(PTHREAD_CFLAGS) $(PTHREAD_LIBS)

# Make is not made aware of per-object dependencies to avoid limiting building parallelization
# But to build the less dependent modules first, we manually select their order here:
EXTRA_LIBRARIES = $(LIBFJARCODE_UTIL) $(LIBFJARCODE_COMMON) \
	$(LIBFJARCODE_CONSENSUS) $(LIBFJARCODE_NODE) \
	$(LIBFJARCODE_CLI) $(LIBFJARCODE_IPC) $(LIBFJARCODE_WALLET) \
	$(LIBFJARCODE_WALLET_TOOL) $(LIBFJARCODE_ZMQ) $(am__append_13) \
	$(MINISKETCH_LIBS) $(LIBTEST_UTIL) $(LIBTEST_FUZZ) \
	$(am__append_62) $(am__append_78)
lib_LTLIBRARIES = $(am__append_26) $(am__append_27)
noinst_LTLIBRARIES = $(LIBFJARCODE_CRYPTO) $(LIBCRC32C_INT) \
	$(am__append_40) $(am__append_42) $(LIBLEVELDB_INT) \
	$(LIBMEMENV_INT) $(LIBUNIVALUE)
BENCHMARKS = 
FJARCODE_INCLUDES = -I$(builddir) -I$(srcdir)/$(MINISKETCH_INCLUDE_DIR_INT) -I$(srcdir)/secp256k1/include -I$(srcdir)/$(UNIVALUE_INCLUDE_DIR_INT)
LIBFJARCODE_NODE = libfjarcode_node.a
LIBFJARCODE_COMMON = libfjarcode_common.a
LIBFJARCODE_CONSENSUS = libfjarcode_consensus.a
LIBFJARCODE_CLI = libfjarcode_cli.a
LIBFJARCODE_UTIL = libfjarcode_util.a
LIBFJARCODE_CRYPTO_BASE = crypto/libfjarcode_crypto_base.la
LIBFJARCODEQT = qt/libfjarcodeqt.a
LIBSECP256K1 = secp256k1/libsecp256k1.la
@ENABLE_ZMQ_TRUE@LIBFJARCODE_ZMQ = libfjarcode_zmq.a
@BUILD_FJARCODE_LIBS_TRUE@LIBFJARCODECONSENSUS = libfjarcodeconsensus.la
@BUILD_FJARCODE_KERNEL_LIB_TRUE@LIBFJARCODEKERNEL = libfjarcodekernel.la
@ENABLE_WALLET_TRUE@LIBFJARCODE_WALLET = libfjarcode_wallet.a
@ENABLE_WALLET_TRUE@LIBFJARCODE_WALLET_TOOL = libfjarcode_wallet_tool.a
LIBFJARCODE_CRYPTO = $(LIBFJARCODE_CRYPTO_BASE) $(am__append_1) \
	$(am__append_2) $(am__append_3) $(am__append_4)
@ENABLE_SSE41_TRUE@LIBFJARCODE_CRYPTO_SSE41 = crypto/libfjarcode_crypto_sse41.la
@ENABLE_AVX2_TRUE@LIBFJARCODE_CRYPTO_AVX2 = crypto/libfjarcode_crypto_avx2.la
@ENABLE_X86_SHANI_TRUE@LIBFJARCODE_CRYPTO_X86_SHANI = crypto/libfjarcode_crypto_x86_shani.la
@ENABLE_ARM_SHANI_TRUE@LIBFJARCODE_CRYPTO_ARM_SHANI = crypto/libfjarcode_crypto_arm_shani.la
