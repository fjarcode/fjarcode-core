@BUILD_FJARCODE_KERNEL_LIB_TRUE@libfjarcodekernel_la_LDFLAGS = $(AM_LDFLAGS) -no-undefined $(RELDFLAGS) $(PTHREAD_FLAGS)
@BUILD_FJARCODE_KERNEL_LIB_TRUE@libfjarcodekernel_la_LIBADD = $(LIBFJARCODE_CRYPTO) $(LIBLEVELDB) $(LIBMEMENV) $(LIBSECP256K1)
@BUILD_FJARCODE_KERNEL_LIB_TRUE@libfjarcodekernel_la_CPPFLAGS = $(AM_CPPFLAGS) -I$(builddir)/obj -I$(srcdir)/secp256k1/include $(BOOST_CPPFLAGS) $(LEVELDB_CPPFLAGS)

# libfjarcodekernel requires default symbol visibility, explicitly specify that
# here so that things still work even when user configures with
#   --enable-reduce-exports
#
# Note this is a quick hack that will be removed as we incrementally define what
# to export from the library.
@BUILD_FJARCODE_KERNEL_LIB_TRUE@libfjarcodekernel_la_CXXFLAGS = $(AM_CXXFLAGS) $(PIE_FLAGS) -fvisibility=default

# TODO: libfjarcodekernel is a work in progress consensus engine library, as more
#       and more modules are decoupled from the consensus engine, this list will
#       shrink to only those which are absolutely necessary.
@BUILD_FJARCODE_KERNEL_LIB_TRUE@libfjarcodekernel_la_SOURCES = \
@BUILD_FJARCODE_KERNEL_LIB_TRUE@  kernel/fjarcodekernel.cpp \
