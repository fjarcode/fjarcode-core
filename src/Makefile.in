	am--depfiles check check-TESTS check-am check-local clean \
	clean-binPROGRAMS clean-checkPROGRAMS clean-generic \
	clean-libLTLIBRARIES clean-libtool clean-local \
	clean-noinstLTLIBRARIES clean-noinstPROGRAMS cscopelist-am \
	ctags ctags-am distclean distclean-compile distclean-generic \
	distclean-libtool distclean-tags distdir dvi dvi-am html \
	html-am info info-am install install-am install-binPROGRAMS \
	install-data install-data-am install-dvi install-dvi-am \
	install-exec install-exec-am install-html install-html-am \
	install-includeHEADERS install-info install-info-am \
	install-libLTLIBRARIES install-man install-pdf install-pdf-am \
	install-ps install-ps-am install-strip installcheck \
	installcheck-am installdirs installdirs-am maintainer-clean \
	maintainer-clean-generic mostlyclean mostlyclean-compile \
	mostlyclean-generic mostlyclean-libtool pdf pdf-am ps ps-am \
	recheck tags tags-am uninstall uninstall-am \
	uninstall-binPROGRAMS uninstall-includeHEADERS \
	uninstall-libLTLIBRARIES

.PRECIOUS: Makefile


# Pattern rule to print variables, e.g. make print-top_srcdir
print-%: FORCE
	@echo '$*'='$($*)'

$(LIBSECP256K1): $(wildcard secp256k1/src/*.h) $(wildcard secp256k1/src/*.c) $(wildcard secp256k1/include/*)
	$(AM_V_at)$(MAKE) $(AM_MAKEFLAGS) -C $(@D) $(@F)

.PHONY: FORCE check-symbols check-security

obj/build.h: FORCE
	@$(MKDIR_P) $(builddir)/obj
	$(AM_V_GEN) $(top_srcdir)/share/genbuild.sh "$(abs_top_builddir)/src/obj/build.h" \
	  "$(abs_top_srcdir)"
libfjarcode_util_a-clientversion.$(OBJEXT): obj/build.h

# Required for obj/build.h to be generated first.
# More details: https://www.gnu.org/software/automake/manual/html_node/Built-Sources-Example.html
@BUILD_FJARCODE_KERNEL_LIB_TRUE@libfjarcodekernel_la-clientversion.l$(OBJEXT): obj/build.h

config/fjarcode-config.h: config/stamp-h1
	@$(MAKE) -C $(top_builddir) $(subdir)/$(@)
config/stamp-h1: $(top_srcdir)/$(subdir)/config/fjarcode-config.h.in $(top_builddir)/config.status
	$(AM_V_at)$(MAKE) -C $(top_builddir) $(subdir)/$(@)
$(top_srcdir)/$(subdir)/config/fjarcode-config.h.in:  $(am__configure_deps)
	$(AM_V_at)$(MAKE) -C $(top_srcdir) $(subdir)/config/fjarcode-config.h.in

clean-local:
	-$(MAKE) -C secp256k1 clean
	-rm -f leveldb/*/*.gcda leveldb/*/*.gcno leveldb/helpers/memenv/*.gcda leveldb/helpers/memenv/*.gcno
	-rm -f config.h
	-rm -rf test/__pycache__

.rc.o:
	@test -f $(WINDRES) || (echo "windres $(WINDRES) not found, but is required to compile windows resource files"; exit 1)
	$(AM_V_GEN) $(WINDRES) $(DEFS) $(DEFAULT_INCLUDES) $(INCLUDES) $(CPPFLAGS) -DWINDRES_PREPROC -i $< -o $@

check-symbols: $(bin_PROGRAMS)
	@echo "Running symbol and dynamic library checks..."
	$(AM_V_at) $(PYTHON) $(top_srcdir)/contrib/devtools/symbol-check.py $(bin_PROGRAMS)

check-security: $(bin_PROGRAMS)
@HARDEN_TRUE@	@echo "Checking binary security..."
@HARDEN_TRUE@	$(AM_V_at) $(PYTHON) $(top_srcdir)/contrib/devtools/security-check.py $(bin_PROGRAMS)
%.capnp:

# Explicitly list dependencies on generated headers as described in
# https://www.gnu.org/software/automake/manual/html_node/Built-Sources-Example.html#Recording-Dependencies-manually
ipc/capnp/libfjarcode_ipc_a-protocol.$(OBJEXT): $(libfjarcode_ipc_mpgen_input:=.h)

@BUILD_MULTIPROCESS_TRUE@include $(MPGEN_PREFIX)/include/mpgen.mk

%.raw.h: %.raw
	@$(MKDIR_P) $(@D)
	$(AM_V_GEN) { \
	 echo "static unsigned const char $(*F)_raw[] = {" && \
	 $(HEXDUMP) -v -e '8/1 "0x%02x, "' -e '"\n"' $< | $(SED) -e 's/0x  ,//g' && \
	 echo "};"; \
	} > "$@.new" && mv -f "$@.new" "$@"

# Generate various .c++/.h files from the ipc_test.capnp file
@BUILD_MULTIPROCESS_TRUE@include $(MPGEN_PREFIX)/include/mpgen.mk

# Explicitly list dependencies on generated headers as described in
# https://www.gnu.org/software/automake/manual/html_node/Built-Sources-Example.html#Recording-Dependencies-manually
test/libfjarcode_ipc_test_a-ipc_test.$(OBJEXT): test/ipc_test.capnp.h

$(FJARCODE_TESTS): $(GENERATED_TEST_FILES)

@TARGET_WINDOWS_TRUE@fjarcode_test: $(TEST_BINARY)
@ENABLE_BENCH_TRUE@@TARGET_WINDOWS_FALSE@fjarcode_test: $(TEST_BINARY) $(BENCH_BINARY)
@ENABLE_BENCH_FALSE@@TARGET_WINDOWS_FALSE@fjarcode_test: $(TEST_BINARY)

fjarcode_test_check: $(TEST_BINARY) FORCE
	$(MAKE) check-TESTS TESTS=$^

fjarcode_test_clean : FORCE
	rm -f $(CLEAN_FJARCODE_TEST) $(test_test_fjarcode_OBJECTS) $(TEST_BINARY)

check-unit: $(FJARCODE_TESTS:.cpp=.cpp.test)

check-local: check-unit
@BUILD_FJARCODE_TX_TRUE@	@echo "Running test/util/test_runner.py..."
@BUILD_FJARCODE_TX_TRUE@	$(PYTHON) $(top_builddir)/test/util/test_runner.py
	@echo "Running test/util/rpcauth-test.py..."
	$(PYTHON) $(top_builddir)/test/util/rpcauth-test.py
@ENABLE_BENCH_TRUE@@TARGET_WINDOWS_FALSE@	@echo "Running bench/bench_fjarcode (one iteration sanity check, only high priority)..."
@ENABLE_BENCH_TRUE@@TARGET_WINDOWS_FALSE@	$(BENCH_BINARY) -sanity-check -priority-level=high
	$(AM_V_at)$(MAKE) $(AM_MAKEFLAGS) -C secp256k1 check

%.cpp.test: %.cpp
	@echo Running tests: $$(\
	  cat $< | \
	  grep -E "(BOOST_FIXTURE_TEST_SUITE\\(|BOOST_AUTO_TEST_SUITE\\()" | \
	  cut -d '(' -f 2 | cut -d ',' -f 1 | cut -d ')' -f 1\
	) from $<
	$(AM_V_at)export TEST_LOGFILE=$(abs_builddir)/$$(\
	  echo $< | grep -E -o "(wallet/test/.*\.cpp|test/.*\.cpp)" | $(SED) -e s/\.cpp/.log/ \
	) && \
	$(TEST_BINARY) --catch_system_errors=no -l test_suite -t "$$(\
	  cat $< | \
	  grep -E "(BOOST_FIXTURE_TEST_SUITE\\(|BOOST_AUTO_TEST_SUITE\\()" | \
	  cut -d '(' -f 2 | cut -d ',' -f 1 | cut -d ')' -f 1\
	)" -- DEBUG_LOG_OUT > "$$TEST_LOGFILE" 2>&1 || (cat "$$TEST_LOGFILE" && false)

%.json.h: %.json
	@$(MKDIR_P) $(@D)
	$(AM_V_GEN) { \
	 echo "#include <string>" && \
	 echo "namespace json_tests{" && \
	 echo "static const std::string $(*F){" && \
	 $(HEXDUMP) -v -e '8/1 "0x%02x, "' -e '"\n"' $< | $(SED) -e 's/0x  ,//g' && \
	 echo "};};"; \
	} > "$@.new" && mv -f "$@.new" "$@"

@ENABLE_BENCH_TRUE@bench/data.cpp: bench/data/block413567.raw.h

@ENABLE_BENCH_TRUE@fjarcode_bench: $(BENCH_BINARY)

@ENABLE_BENCH_TRUE@bench: $(BENCH_BINARY) FORCE
@ENABLE_BENCH_TRUE@	$(BENCH_BINARY)

@ENABLE_BENCH_TRUE@fjarcode_bench_clean : FORCE
@ENABLE_BENCH_TRUE@	rm -f $(CLEAN_FJARCODE_BENCH) $(bench_bench_fjarcode_OBJECTS) $(BENCH_BINARY)

# Most files will depend on the forms and moc files as includes. Generate them
# before anything else.
@ENABLE_QT_TRUE@$(QT_MOC): $(QT_FORMS_H)
@ENABLE_QT_TRUE@$(qt_libfjarcodeqt_a_OBJECTS) $(qt_fjarcode_qt_OBJECTS) $(fjarcode_gui_OBJECTS) : | $(QT_MOC)

@ENABLE_QT_TRUE@SECONDARY: $(QT_QM)

@ENABLE_QT_TRUE@$(srcdir)/qt/fjarcodestrings.cpp: FORCE
@ENABLE_QT_TRUE@	@test -n $(XGETTEXT) || echo "xgettext is required for updating translations"
@ENABLE_QT_TRUE@	$(AM_V_GEN) cd $(srcdir); XGETTEXT=$(XGETTEXT) COPYRIGHT_HOLDERS="$(COPYRIGHT_HOLDERS)" $(PYTHON) ../share/qt/extract_strings_qt.py \
@ENABLE_QT_TRUE@    $(libfjarcode_node_a_SOURCES) $(libfjarcode_wallet_a_SOURCES) $(libfjarcode_common_a_SOURCES) \
@ENABLE_QT_TRUE@    $(libfjarcode_zmq_a_SOURCES) $(libfjarcode_consensus_a_SOURCES) $(libfjarcode_util_a_SOURCES) \
@ENABLE_QT_TRUE@    $(FJARCODE_QT_BASE_CPP) $(FJARCODE_QT_WINDOWS_CPP) $(FJARCODE_QT_WALLET_CPP) $(FJARCODE_QT_H) $(FJARCODE_MM)

# The resulted fjarcode_en.xlf source file should follow Transifex requirements.
# See: https://docs.transifex.com/formats/xliff#how-to-distinguish-between-a-source-file-and-a-translation-file
@ENABLE_QT_TRUE@translate: $(srcdir)/qt/fjarcodestrings.cpp $(QT_FORMS_UI) $(QT_FORMS_UI) $(FJARCODE_QT_BASE_CPP) $(FJARCODE_QT_WINDOWS_CPP) $(FJARCODE_QT_WALLET_CPP) $(FJARCODE_QT_H) $(FJARCODE_MM)
@ENABLE_QT_TRUE@	@test -n $(LUPDATE) || echo "lupdate is required for updating translations"
@ENABLE_QT_TRUE@	$(AM_V_GEN) QT_SELECT=$(QT_SELECT) $(LUPDATE) -no-obsolete -I $(srcdir) -locations relative $^ -ts $(srcdir)/qt/locale/fjarcode_en.ts
@ENABLE_QT_TRUE@	@test -n $(LCONVERT) || echo "lconvert is required for updating translations"
@ENABLE_QT_TRUE@	$(AM_V_GEN) QT_SELECT=$(QT_SELECT) $(LCONVERT) -drop-translations -o $(srcdir)/qt/locale/fjarcode_en.xlf -i $(srcdir)/qt/locale/fjarcode_en.ts
@ENABLE_QT_TRUE@	@$(SED) -i.old -e 's|source-language="en" target-language="en"|source-language="en"|' -e '/<target xml:space="preserve"><\/target>/d' $(srcdir)/qt/locale/fjarcode_en.xlf
@ENABLE_QT_TRUE@	@rm -f $(srcdir)/qt/locale/fjarcode_en.xlf.old

@ENABLE_QT_TRUE@$(QT_QRC_LOCALE_CPP): $(QT_QRC_LOCALE) $(QT_QM)
@ENABLE_QT_TRUE@	@test -f $(RCC) || (echo "rcc $(RCC) not found, but is required for generating qrc cpp files"; exit 1)
@ENABLE_QT_TRUE@	@cp -f $< $(@D)/temp_$(<F)
@ENABLE_QT_TRUE@	$(AM_V_GEN) QT_SELECT=$(QT_SELECT) $(RCC) -name fjarcode_locale --format-version 1 $(@D)/temp_$(<F) > $@
@ENABLE_QT_TRUE@	@rm $(@D)/temp_$(<F)

@ENABLE_QT_TRUE@$(QT_QRC_CPP): $(QT_QRC) $(QT_FORMS_H) $(QT_RES_FONTS) $(QT_RES_ICONS) $(QT_RES_ANIMATION)
@ENABLE_QT_TRUE@	@test -f $(RCC) || (echo "rcc $(RCC) not found, but is required for generating qrc cpp files"; exit 1)
@ENABLE_QT_TRUE@	$(AM_V_GEN) QT_SELECT=$(QT_SELECT) $(RCC) -name fjarcode --format-version 1 $< > $@

@ENABLE_QT_TRUE@fjarcode_qt_clean: FORCE
@ENABLE_QT_TRUE@	rm -f $(CLEAN_QT) $(qt_libfjarcodeqt_a_OBJECTS) $(qt_fjarcode_qt_OBJECTS) qt/fjarcode-qt$(EXEEXT) $(LIBFJARCODEQT)

@ENABLE_QT_TRUE@fjarcode_qt : qt/fjarcode-qt$(EXEEXT)

@ENABLE_QT_TRUE@fjarcode_qt_apk: FORCE
@ENABLE_QT_TRUE@	mkdir -p $(APK_LIB_DIR)
@ENABLE_QT_TRUE@	cp $(dir $(lastword $(CC)))../sysroot/usr/lib/$(host_alias)/libc++_shared.so $(APK_LIB_DIR)
@ENABLE_QT_TRUE@	tar xf $(QT_BASE_PATH) -C qt/android/src/ $(QT_BASE_TLD)src/android/jar/src --strip-components=5
@ENABLE_QT_TRUE@	tar xf $(QT_BASE_PATH) -C qt/android/src/ $(QT_BASE_TLD)src/android/java/src --strip-components=5
@ENABLE_QT_TRUE@	cp qt/fjarcode-qt $(APK_LIB_DIR)/libfjarcode-qt_$(ANDROID_ARCH).so
@ENABLE_QT_TRUE@	cd qt/android && gradle wrapper --gradle-version=6.6.1
@ENABLE_QT_TRUE@	cd qt/android && ./gradlew build

@ENABLE_QT_TRUE@ui_%.h: %.ui
@ENABLE_QT_TRUE@	@test -f $(UIC) || (echo "uic $(UIC) not found, but is required for generating ui headers"; exit 1)
@ENABLE_QT_TRUE@	@$(MKDIR_P) $(@D)
@ENABLE_QT_TRUE@	$(AM_V_GEN) QT_SELECT=$(QT_SELECT) $(UIC) -o $@ $< || (echo "Error creating $@"; false)

@ENABLE_QT_TRUE@%.moc: %.cpp
@ENABLE_QT_TRUE@	$(AM_V_GEN) QT_SELECT=$(QT_SELECT) $(MOC) $(DEFAULT_INCLUDES) $(QT_INCLUDES_UNSUPPRESSED) $(MOC_DEFS) $< > $@

@ENABLE_QT_TRUE@moc_%.cpp: %.h
@ENABLE_QT_TRUE@	$(AM_V_GEN) QT_SELECT=$(QT_SELECT) $(MOC) $(DEFAULT_INCLUDES) $(QT_INCLUDES_UNSUPPRESSED) $(MOC_DEFS) $< > $@

@ENABLE_QT_TRUE@%.qm: %.ts
@ENABLE_QT_TRUE@	@test -f $(LRELEASE) || (echo "lrelease $(LRELEASE) not found, but is required for generating translations"; exit 1)
@ENABLE_QT_TRUE@	@$(MKDIR_P) $(@D)
@ENABLE_QT_TRUE@	$(AM_V_GEN) QT_SELECT=$(QT_SELECT) $(LRELEASE) -silent $< -qm $@

@ENABLE_QT_TESTS_TRUE@test_fjarcode_qt : qt/test/test_fjarcode-qt$(EXEEXT)

@ENABLE_QT_TESTS_TRUE@test_fjarcode_qt_check : qt/test/test_fjarcode-qt$(EXEEXT) FORCE
@ENABLE_QT_TESTS_TRUE@	$(MAKE) check-TESTS TESTS=$^

@ENABLE_QT_TESTS_TRUE@test_fjarcode_qt_clean: FORCE
@ENABLE_QT_TESTS_TRUE@	rm -f $(CLEAN_FJARCODE_QT_TEST) $(qt_test_test_fjarcode_qt_OBJECTS)

# Tell versions [3.59,3.63) of GNU make to not export all variables.
# Otherwise a system limit (for SysV at least) may be exceeded.
.NOEXPORT:

# Tell GNU make to disable its built-in pattern rules.
%:: %,v
%:: RCS/%,v
%:: RCS/%
%:: s.%
%:: SCCS/s.%
